# boxBot Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it contains secrets.

# Claude API
ANTHROPIC_API_KEY=

# Models — large for conversations/reasoning, small for classification/tagging
BOXBOT_MODEL_LARGE=claude-sonnet-4-20250514
BOXBOT_MODEL_SMALL=claude-haiku-4-5-20251001

# Speech-to-Text (choose one)
OPENAI_API_KEY=          # For Whisper API
# DEEPGRAM_API_KEY=      # For Deepgram

# Text-to-Speech
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Google Calendar (optional)
# Path to OAuth client secrets JSON downloaded from Google Cloud Console
# (Desktop app credentials). After setting, run scripts/calendar_auth.py
# once to grant calendar access. The resulting token auto-refreshes.
# GOOGLE_CALENDAR_CLIENT_SECRETS=data/credentials/google_client_secrets.json
# GOOGLE_CALENDAR_TOKEN=data/credentials/google_calendar_token.json
# GOOGLE_CALENDAR_ID=primary

# Cloud backup (optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# Weather (NOAA — US-only, no API key required)
# Decimal degrees, negative for west / south
# BOXBOT_WEATHER_LAT=45.493336
# BOXBOT_WEATHER_LON=-122.915988

# HuggingFace (required for pyannote.audio diarization models)
# Free token from https://huggingface.co/settings/tokens
# Also accept the user agreements at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/embedding
# HF_TOKEN=
