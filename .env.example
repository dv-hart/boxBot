# boxBot Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it contains secrets.

# Claude API
ANTHROPIC_API_KEY=

# Models — large for conversations/reasoning, small for classification/tagging
BOXBOT_MODEL_LARGE=claude-sonnet-4-20250514
BOXBOT_MODEL_SMALL=claude-haiku-4-5-20251001

# Speech-to-Text (choose one)
OPENAI_API_KEY=          # For Whisper API
# DEEPGRAM_API_KEY=      # For Deepgram

# Text-to-Speech
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Cloud backup (optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
